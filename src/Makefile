SRC	 =	main.cpp

OBJ	 =	$(SRC:.cpp=.o)
NAME =	arcade

LIBS_DIR	=	lib

all:	$(NAME)

$(NAME):	$(OBJ) $(LIBS_DIR)/lib1/lib1.so
	g++ -Wall -Wextra -o $(NAME) $(OBJ) -ldl -fno-gnu-unique

clean:
	rm -f $(OBJ)

fclean:		clean
	rm -f $(NAME)

re:			fclean all

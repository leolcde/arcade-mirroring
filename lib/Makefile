LIB1_SRC	=	graphics/NCurses.cpp

LIB1_SO		=	graphics/NCurses.so

LIB1_OBJ	=	$(LIB1_SRC:.cpp=.o)

all:		$(LIB1_SO)

$(LIB1_SO):	$(LIB1_OBJ)
	g++ -Wall -Wextra -fPIC -shared -o $@ $^

%.o: %.cpp
	g++ -Wall -Wextra -fPIC -c -o $@ $<

clean:
	rm -f $(LIB1_OBJ)

fclean:		clean
	rm -f $(LIB1_SO)

re:			fclean all
